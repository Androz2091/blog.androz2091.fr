---
import { SITE_TITLE, SITE_DESCRIPTION_FR } from '../consts';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getPostsByLang, postUrl, getExcerpt } from '../lib/posts';

const posts = await getPostsByLang('fr');
---

<!doctype html>
<html lang="fr">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION_FR} lang="fr" />
  </head>
  <body>
    <main>
      <Header lang="fr" frHref="/" enHref="/en/" />
      {
        posts.map((post) => (
          <article class:list={['post-summary', { featured: post.data.featured }]}>
            <header>
              <h2>
                <a class="post-link" href={postUrl(post)}>
                  {post.data.title}
                </a>
              </h2>
              <small>
                {post.data.featured && <span class="badge">À la une</span>}
                <FormattedDate date={post.data.date} lang="fr" />
              </small>
            </header>
            <section>
              <p>{getExcerpt(post)}</p>
            </section>
          </article>
        ))
      }
      <Footer />
    </main>
  </body>
</html>

<style>
  .post-summary {
    margin: 0 0 2rem;
  }
  .post-summary:first-of-type {
    margin-top: 2.5rem;
  }
  .post-summary h2 {
    margin: 0 0 4px;
  }
  .post-link {
    color: var(--primary);
    text-decoration: none;
  }
  .post-link:hover {
    text-decoration: underline;
  }
  .post-summary section p {
    margin: 0.5rem 0 0;
  }
  .badge {
    display: inline-block;
    margin-right: 0.5rem;
    padding: 0.1rem 0.45rem;
    border-radius: 999px;
    background: #daa520;
    color: #fff;
    font-size: 0.75em;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
</style>
