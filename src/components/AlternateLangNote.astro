---
import type { Lang } from '../lib/posts';

interface Props {
  current: Lang;
  href: string;
}

const { current, href } = Astro.props;
const label =
  current === 'en'
    ? 'Automatically translated from French by an LLM — read the original'
    : 'Also available in English';
---

<a class="alt-lang" href={href} hreflang={current === 'fr' ? 'en' : 'fr'}>
  <span class="label">{label}</span>
  <span class="arrow">→</span>
</a>

<style>
  .alt-lang {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin: 1.5rem 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--muted);
    border-radius: 6px;
    background: var(--highlight);
    color: var(--text);
    text-decoration: none;
    font-size: 0.95rem;
    transition: border-color 0.15s, background-color 0.15s;
  }
  .alt-lang:hover {
    border-color: var(--primary);
    background: rgba(0, 122, 172, 0.08);
  }
  .alt-lang:hover .arrow {
    transform: translateX(3px);
  }
  .label {
    flex: 1;
    color: var(--meta);
  }
  .alt-lang:hover .label {
    color: var(--primary);
  }
  .arrow {
    color: var(--primary);
    font-weight: 600;
    transition: transform 0.15s;
  }
</style>
